{% extends 'base.html.twig' %}

{% block title %}Mon panier - GreenGoodies{% endblock %}

{% block body %}
<main class="cart_page">

    <h1 class="cart_title">Mon panier</h1>

    {% if cartItems is empty %}
        <div class="cart_empty">
            <p>Votre panier est vide.</p>
            <a href="{{ path('app_home') }}" class="btn_validate">Continuer mes achats</a>
        </div>
    {% else %}

        <div class="cart_clear_wrapper">
            <a href="{{ path('app_cart_clear') }}"
               class="btn_clear"
               onclick="return confirm('Êtes-vous sûr de vouloir vider votre panier ?')">
                &times; Vider le panier
            </a>
        </div>

        <div class="cart_card">
            {% set total = 0 %}
            {% for item in cartItems %}
                {% set sousTotal = item.product.price * item.quantity %}
                {% set total = total + sousTotal %}

                <div class="cart_item {% if not loop.last %}cart_item_border{% endif %}">
                    <div class="cart_item_image_wrapper">
                        <img
                            src="{{ asset(item.product.image) }}"
                            alt="{{ item.product.name }}"
                            class="cart_item_image"
                        >
                    </div>
                    <div class="cart_item_details">
                        <p class="cart_item_name">{{ item.product.name }}</p>
                        <p class="cart_item_qty">Quantité : {{ item.quantity }}</p>
                        <p class="cart_item_price">{{ (item.product.price * item.quantity)|number_format(2, ',', ' ') }}&nbsp;€</p>
                    </div>
                </div>

            {% endfor %}

            <div class="cart_summary">
                <div class="cart_summary_line">
                    <span class="cart_summary_label">Total panier :</span>
                    <span class="cart_summary_total">{{ total|number_format(2, ',', ' ') }}&nbsp;€</span>
                </div>
                <div class="cart_summary_line">
                    <span></span>
                    <span class="cart_shipping_label">Frais de livraison : Offert</span>
                </div>
            </div>
        </div>

        <div class="cart_validate_wrapper">
            <a href="{{ path('app_cart_validate') }}" class="btn_validate">
                Valider la commande
            </a>
        </div>

    {% endif %}

</main>
{% endblock %}
